$ign = @'
.vs/
.vscode/
bin/
obj/
*.suo
*.user
*.userosscache
*.sln.docstates
*.vsidx
*.key
identity_store.json
server.key
'@
Set-Content -Path .gitignore -Value $ign -Encoding utf8

$attr = @'
* text=auto
*.sh text eol=lf
*.ps1 text eol=crlf
*.md text
*.go text
'@
Set-Content -Path .gitattributes -Value $attr -Encoding utf8